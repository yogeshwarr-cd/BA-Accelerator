# Database Configuration
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ba_accelerator

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# LLM Providers API Keys
GROQ_API_KEY=your-groq-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here

# S3 / MinIO Configuration
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=ba-requirements

# API Configuration
API_KEY=ba-accelerator-secure-api-key-12345
PORT=8000
HOST=0.0.0.0

# Third Party Connector Settings (Optional)
JIRA_API_URL=https://your-domain.atlassian.net
JIRA_USERNAME=your-jira-email@domain.com
JIRA_API_TOKEN=your-jira-api-token

CONFLUENCE_API_URL=https://your-domain.atlassian.net/wiki
CONFLUENCE_USERNAME=your-confluence-email@domain.com
CONFLUENCE_API_TOKEN=your-confluence-api-token

SHAREPOINT_SITE_URL=https://yourtenant.sharepoint.com/sites/yoursite
SHAREPOINT_CLIENT_ID=your-azure-app-client-id
SHAREPOINT_CLIENT_SECRET=your-azure-app-client-secret

GOOGLE_DRIVE_CREDENTIALS_JSON=path/to/credentials.json

# INTEGRATION NOTE
# This environment file provides template variables for setting up the local runtime.
# Duplicate this file to '.env' and populate with valid secret keys before starting.

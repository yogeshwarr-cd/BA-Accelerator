# ──────────────────────────────────────────────────────────
#  designlab-core — Environment Variables Template
#  Copy this file to .env and fill in real values.
#  NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────

# Environment: local | dev | staging | production
APP_ENV=local

# ── LLM Provider Keys ────────────────────────────────────
# The system supports ANY provider via {provider}_api_key pattern.
# Add whichever providers you need - all are optional.
# Examples:

# ANTHROPIC_API_KEY=sk-ant-api03-xxxxx
# OPENAI_API_KEY=sk-xxxxx
# ... any provider you want!

# ── Base Domain URLs (per environment) ───────────────────
# These are the base URLs for downstream services.
# Accelerators can read these from the shared .env,
# or override specific keys in their own .env.

API_BASE_URL=http://localhost:8000

# ── LLM Defaults ─────────────────────────────────────────
DEFAULT_LLM_MODEL=claude-3-5-sonnet-20241022
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=3
# LLM_MAX_TOKENS=4096
# LLM_RETRY_MAX_MULTIPLIER=8

# ── API & Prompts Defaults ───────────────────────────────
# API_MIN_FEATURE_LENGTH=10
# PROMPTS_MAX_LIST_DISPLAY=10

# ── Logging ──────────────────────────────────────────────
LOG_LEVEL=INFO
# LOG_FILE_PATH=logs/designlab.txt
# LOG_FILE_LEVEL=INFO
# LOG_FILE_MAX_BYTES=10485760
# LOG_FILE_BACKUP_COUNT=5
